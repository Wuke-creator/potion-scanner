# =====================================================================
# Potion Discord -> Telegram Signals Bot - environment template
# Copy to .env and fill in. Never commit .env to git.
# =====================================================================

# ----- Discord listener (bot reading Potion channels) -----

# Bot token from https://discord.com/developers/applications
# Enable the "Message Content Intent" privileged intent.
DISCORD_BOT_TOKEN=

# Potion guild ID (server ID)
POTION_GUILD_ID=1260259552763580537

# Channel IDs to monitor
PREDICTION_CHANNEL_ID=1420272690459181118
MANUAL_PERP_CHANNEL_ID=1316518499283370064
MACS_CALLS_CHANNEL_ID=1495099327004016791
PINGU_CHARTS_CHANNEL_ID=1496462225945268385
BONDS_CHANNEL_ID=1495502715193917542
WALLET_TRACKER_CHANNEL_ID=1308117198463696967


# ----- Referral links attached to forwarded calls -----

REF_LINK_PERPS=https://partner.blofin.com/d/potion
REF_LINK_MEMECOIN=https://trade.padre.gg/rk/orangie


# ----- Telegram DM bot -----

# Bot token from @BotFather.
# The bot DMs each verified user directly - there is no shared group.
# Users must /start the bot once (open a chat) before they can be DM'd.
TELEGRAM_BOT_TOKEN=


# ----- Dispatcher (DM fan-out rate limits) -----

# Telegram's global bot API limit is ~30 msgs/sec across all chats.
# 25 leaves headroom for reverify cron + command replies.
# At 25/sec: 500 users = 20s fan-out, 1000 users = 40s, 2000 users = 80s.
DISPATCHER_RATE_PER_SEC=25
DISPATCHER_MAX_CONCURRENT=25


# ----- Discord OAuth (Elite verification) -----

# Uses the SAME Discord application as DISCORD_BOT_TOKEN above.
# Go to https://discord.com/developers/applications/{YOUR_APP_ID}/oauth2
#
# Client ID = your Discord application ID (same as the bot ID).
# Client Secret = click "Reset Secret" on the OAuth2 page and copy once.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# The Discord role ID for Elite members in the Potion guild.
# Get this by enabling Developer Mode in Discord (User Settings -> Advanced)
# then right-clicking the Elite role -> Copy Role ID.
DISCORD_ELITE_ROLE_ID=

# URL shown to non-Elite users in the denial DM.
ELITE_SIGNUP_URL=https://whop.com/potion

# Cancel-survey DM watcher: when a member loses the Elite role, the bot
# DMs them this URL with ?type=exit&member_id=...&username=... appended.
# Leave empty to disable the watcher.
CANCEL_SURVEY_URL=https://potion-feedback.netlify.app


# ----- OAuth callback server -----

# Public HTTPS URL of the /oauth/discord/callback endpoint.
# - Local dev: ngrok http 8080 -> https://abc123.ngrok.io/oauth/discord/callback
# - Production: your real domain pointing at this container
# This URL must ALSO be added to the Discord application's OAuth2 Redirects.
OAUTH_REDIRECT_URI=

# Port the aiohttp callback server listens on inside the container.
OAUTH_PORT=8080

# 32+ random hex characters used to HMAC-sign the OAuth state token.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_STATE_SECRET=

# Fernet key used to encrypt Discord refresh tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WHOP_REFRESH_TOKEN_ENCRYPTION_KEY=


# ----- Email bot (win-back + re-engagement) -----

# Set to "true" to turn the email subsystem on. When false (or missing)
# the rest of the bot still works fine and email routes are unmounted.
EMAIL_BOT_ENABLED=false

# Resend API key (https://resend.com/api-keys). Only needed when enabled.
RESEND_API_KEY=

# Sending address. Must match a verified domain in your Resend account.
# Format: "Display Name <addr@your-verified-domain.com>"
RESEND_FROM_ADDRESS=Potion Alpha Team <team@potion.gg>

# HMAC-SHA256 shared secret for Whop webhook signature verification.
# Get this from the Whop developer dashboard when creating the webhook.
WHOP_WEBHOOK_SECRET=

# Shared secret for internal /webhook/inactivity + /admin/email/* routes.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_WEBHOOK_SECRET=

# Whop checkout / rejoin URL used as the default CTA in every email.
POTION_REJOIN_URL=https://whop.com/potion

# Comma-separated Discord user IDs allowed to run /email-* slash commands.
# Example: DISCORD_ADMIN_USER_IDS=901091776977338419,222344473235947520
DISCORD_ADMIN_USER_IDS=

# ----- Whop API (backfills email column on verified_users) -----
# Used by the startup email sync + /sync-emails slash command to look up a
# member's email in Whop by their linked Discord user ID. Needed for Features
# 2 and 4 which rely on email delivery. Without this key those features
# gracefully no-op on users with empty email.
#
# Create the API key at:
#   https://whop.com/dashboard/biz_pn9Fq67uJNjgj1/developer/api-keys
# Company ID is the Potion Whop business id (safe to commit).
WHOP_API_KEY=
WHOP_COMPANY_ID=biz_pn9Fq67uJNjgj1

# Separate Whop API key scoped only to promo_code:create + access_pass:basic:read.
# Bot uses it to mint single-use promo codes per cancelling member so leaked
# codes can only be redeemed once. Kept isolated from WHOP_API_KEY so a leak
# of either has minimal blast radius. Leave blank to fall back to the hardcoded
# offer codes in the frontend.
WHOP_PROMO_API_KEY=


# ----- Logging -----

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
